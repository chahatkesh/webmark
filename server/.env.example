# Environment variables
PORT=4000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/webmark
JWT_SECRET=your_jwt_secret_here

# Frontend URL
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
ALLOW_VERCEL_PREVIEWS=false

# Google OAuth credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
SERVER_URL=http://localhost:4000

# Auth/session cookies
ACCESS_TOKEN_TTL=15m
ACCESS_COOKIE_MAX_AGE_SECONDS=900
SESSION_MAX_AGE_DAYS=365
REFRESH_REUSE_WINDOW_SECONDS=30
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.example.com

# Scheduled stats collection
CRON_SECRET=replace_with_a_long_random_value
ENABLE_LOCAL_CRON=true
RUN_CRON_ON_STARTUP=false
PUBLIC_STATS_CACHE_TTL_SECONDS=300

# OpenAI (for AI bookmark categorization)
OPENAI_API_KEY=sk-your-openai-key-here
