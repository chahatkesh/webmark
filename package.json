{
  "name": "webmark",
  "private": true,
  "scripts": {
    "dev": "mprocs",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "prepare": "husky",
    "lint": "pnpm --filter client run lint && pnpm --filter server run lint",
    "type-check": "pnpm --filter client run type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "mprocs": "^0.9.6",
    "prettier": "^3.5.3"
  },
  "lint-staged": {
    "client/**/*.{js,jsx}": "prettier --check",
    "server/**/*.js": "prettier --check",
    "*.{json,md,yml,yaml,css}": "prettier --check"
  },
  "packageManager": "pnpm@10.34.4+sha512.8768be55200ae3f2226b6527fcca2687e14bc4e5f12d7721a0f25da3df47915177058648db4177baf348120fa0ba2752d8d8d93f6beaf1fe64ae18da8de961af"
}
